---
// Pricing tiers: a responsive grid of plan cards. One tier may be `featured`
// (accent ring). Renders only the prices/fields supplied — never invents numbers.
const { section } = Astro.props;
const tiers = section.tiers ?? [];
const cols = tiers.length === 2 ? 'lg:grid-cols-2' : 'lg:grid-cols-3';
---
<section class="bg-bg-muted">
  <div class="mx-auto max-w-ac px-6 py-16 sm:py-20">
    {section.heading && (
      <h2 class="reveal font-heading text-2xl font-semibold text-ink sm:text-3xl">{section.heading}</h2>
    )}
    {section.subhead && <p class="reveal mt-3 max-w-2xl text-muted">{section.subhead}</p>}
    <div class={`mt-10 grid gap-6 sm:grid-cols-2 ${cols}`}>
      {tiers.map((t) => (
        <div class={`reveal flex flex-col rounded-ac border bg-bg p-6 shadow-ac ${t.featured ? 'border-accent ring-1 ring-accent' : 'border-line'}`}>
          {t.featured && (
            <span class="mb-3 inline-flex w-fit items-center rounded-full bg-accent px-3 py-1 text-xs font-semibold uppercase tracking-wide text-accent-contrast">Most popular</span>
          )}
          <h3 class="font-heading text-lg font-semibold text-ink">{t.name}</h3>
          {t.price && (
            <p class="mt-3 font-heading text-3xl font-semibold text-ink">
              {t.price}
              {t.cadence && <span class="ml-1 align-middle text-sm font-normal text-muted">{t.cadence}</span>}
            </p>
          )}
          {t.description && <p class="mt-3 text-sm text-muted">{t.description}</p>}
          {(t.includes ?? []).length > 0 && (
            <ul class="mt-6 space-y-2 text-sm">
              {t.includes.map((it) => (
                <li class="flex gap-3 text-muted"><svg aria-hidden="true" class="mt-1 h-4 w-4 flex-none text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg><span>{it}</span></li>
              ))}
            </ul>
          )}
          {t.cta && (
            <a href={t.cta.href} class={`mt-8 inline-flex items-center justify-center rounded-ac px-5 py-3 font-medium shadow-ac transition-transform hover:-translate-y-0.5 ${t.featured ? 'bg-accent text-accent-contrast' : 'bg-primary text-primary-contrast'}`}>{t.cta.label}</a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
