---
const { content } = Astro.props;
const { meta, nap, nav = [], footer = {} } = content;
const year = new Date().getFullYear();
---
<footer class="border-t border-line bg-bg-muted">
  <div class="mx-auto grid max-w-ac gap-8 px-6 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <p class="font-heading text-lg font-semibold text-ink">{meta.businessName}</p>
      {footer.blurb && <p class="mt-2 text-sm text-muted">{footer.blurb}</p>}
    </div>
    <nav aria-label="Footer">
      <p class="text-xs font-semibold uppercase tracking-wide text-muted">Explore</p>
      <ul class="mt-3 space-y-2">
        {nav.map((item) => (
          <li><a href={item.href} class="text-sm text-muted hover:text-ink">{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-muted">Contact</p>
      <ul class="mt-3 space-y-2 text-sm text-muted">
        {nap.phone && <li><a href={`tel:${nap.phone}`} class="hover:text-ink">{nap.phone}</a></li>}
        {nap.email && <li><a href={`mailto:${nap.email}`} class="hover:text-ink">{nap.email}</a></li>}
        {(nap.streetAddress || nap.addressLocality) && (
          <li>{[nap.streetAddress, nap.addressLocality, nap.addressRegion, nap.postalCode].filter(Boolean).join(', ')}</li>
        )}
      </ul>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-muted">Hours</p>
      <ul class="mt-3 space-y-2 text-sm text-muted">
        {footer.showHours && nap.hours && <li>{nap.hours}</li>}
        {nap.serviceArea && <li>{nap.serviceArea}</li>}
      </ul>
    </div>
  </div>
  <div class="border-t border-line">
    <p class="mx-auto max-w-ac px-6 py-5 text-xs text-muted">
      © {year} {nap.name || meta.businessName}. All rights reserved.
    </p>
  </div>
</footer>
