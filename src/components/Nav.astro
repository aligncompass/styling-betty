---
import { cldUrl } from '../lib/cloudinary.js';
const { content } = Astro.props;
const { meta, nav = [], cta, cloudinary = {}, branding = {} } = content;
const ui = content.ui ?? {};
const i18nOn = content.i18n?.enabled;
const other = (meta.lang === 'es') ? { label: 'EN', lang: 'en', title: 'View in English' } : { label: 'ES', lang: 'es', title: 'Ver en español' };
const _p = (Astro.url.pathname.replace(/\/+$/, '') || '/');
const _baseSeg = (meta.base && meta.base !== '/') ? meta.base.replace(/\/$/, '') : '';
let _rel = (_baseSeg && _p.startsWith(_baseSeg)) ? (_p.slice(_baseSeg.length) || '/') : _p;
if (!_rel.startsWith('/')) _rel = '/' + _rel;
const _otherSeg = (meta.lang === 'es') ? '' : '/es';
const langHref = (_otherSeg + (_rel === '/' ? '/' : _rel)) || '/';
const logo = branding.logo;
const logoUrl = logo && cloudinary.cloudName ? cldUrl(cloudinary.cloudName, logo.publicId, { width: 96, transforms: logo.transforms || 'c_fit,f_png' }) : '';
const here = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (href) => here === href.replace(/\/$/, '');
const home = nav[0]?.href || meta.base || '/';
---
<header class="sticky top-0 z-40 border-b border-line bg-bg/85 backdrop-blur">
  <div class="mx-auto flex max-w-ac items-center justify-between gap-4 px-6 py-4">
    <a href={home} class="flex items-center gap-2.5">
      {logoUrl && <img src={logoUrl} alt={logo.alt || meta.businessName} width="48" height="40" class="h-10 w-auto" />}
      <span class="font-heading text-lg font-semibold text-ink">{meta.businessName}</span>
    </a>
    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrent(item.href) ? 'page' : undefined}
          class={`text-sm text-muted transition-colors hover:text-ink ${isCurrent(item.href) ? 'text-ink' : ''}`}
        >{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      {i18nOn && (
        <a href={langHref} hreflang={other.lang} title={other.title} aria-label={other.title} class="inline-flex items-center rounded-ac border border-line px-2.5 py-2 text-sm font-medium text-ink transition-colors hover:bg-bg-muted">{other.label}</a>
      )}
      {cta?.primary && (
        <a
          href={cta.primary.href}
          target={cta.primary.href.startsWith('http') ? '_blank' : undefined}
          rel={cta.primary.href.startsWith('http') ? 'noopener' : undefined}
          class="inline-flex items-center rounded-ac bg-accent px-4 py-2 text-sm font-medium text-accent-contrast shadow-ac transition-transform hover:-translate-y-0.5"
        >{cta.primary.label}</a>
      )}
      <details class="relative md:hidden">
        <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-ac border border-line text-ink [&::-webkit-details-marker]:hidden" aria-label={ui.openMenu || 'Open menu'}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </summary>
        <div class="absolute right-0 z-50 mt-3 w-56 rounded-ac border border-line bg-bg p-2 shadow-ac">
          {nav.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
              class={`block rounded-ac px-3 py-2 text-sm transition-colors hover:bg-bg-muted ${isCurrent(item.href) ? 'text-ink' : 'text-muted'}`}
            >{item.label}</a>
          ))}
          {i18nOn && (
            <a href={langHref} hreflang={other.lang} class="mt-1 block rounded-ac px-3 py-2 text-sm font-medium text-ink transition-colors hover:bg-bg-muted">{other.lang === 'es' ? 'Español' : 'English'}</a>
          )}
        </div>
      </details>
    </div>
  </div>
</header>
